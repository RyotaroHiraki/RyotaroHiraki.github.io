<div class="homepage-badges">
  {% if page.homepage_badges.keywords %}
    <div class="homepage-badges__keywords">
      {% for keyword in page.homepage_badges.keywords %}
        <span>{{ keyword }}</span>
      {% endfor %}
    </div>
  {% endif %}

  {% if page.homepage_badges.icons %}
    <div class="homepage-badges__icons">
      {% for item in page.homepage_badges.icons %}
        <a href="{{ item.url }}" aria-label="{{ item.label }}" title="{{ item.label }}">
          {% if item.icon == 'google-scholar' %}
            <i class="ai ai-google-scholar"></i>
          {% elsif item.icon == 'envelope' %}
            <i class="fa-solid fa-envelope"></i>
          {% else %}
            <i class="{{ item.icon }}"></i>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  {% endif %}
</div>

<style>
  .homepage-badges {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    margin: 1rem 0 1.5rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--global-divider-color);
    border-radius: 8px;
    background: var(--global-card-bg-color);
  }

  .homepage-badges__icons {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 1.25rem;
  }

  .homepage-badges__icons a {
    color: var(--global-text-color);
  }

  .homepage-badges__icons a:hover {
    color: var(--global-theme-color);
  }

  .homepage-badges__keywords {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .homepage-badges__keywords span {
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    color: var(--global-theme-color);
    background: var(--global-bg-color);
    font-size: 0.85rem;
    line-height: 1.4;
  }
</style>
